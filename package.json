{
  "name": "@tapir19/contracts",
  "version": "1.0.9",
  "description": "Protobufs definitions and generated TypeScript types",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./gen/account": {
      "types": "./dist/gen/account.d.ts",
      "default": "./dist/gen/account.js"
    },
    "./gen/auth": {
      "types": "./dist/gen/auth.d.ts",
      "default": "./dist/gen/auth.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate": "protoc --plugin=protoc-gen-ts_proto=$(yarn bin protoc-gen-ts_proto) -I ./proto ./proto/*.proto --ts_proto_out=./gen --ts_proto_opt=nestJs=true,package=omit"
  },
  "files": [
    "dist",
    "proto",
    "gen"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@nestjs/microservices": "^11.1.13",
    "rxjs": "^7.8.2",
    "ts-proto": "^2.11.2"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3"
  }
}
